APP_NAME=E-Tutoring
APP_ENV=local
APP_KEY=base64:replace-with-generated-app-key
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=daily
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=e_tutoring
DB_USERNAME=laravel
DB_PASSWORD=laravel_password

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax
SANCTUM_EXPIRATION=43200

CORS_ALLOWED_ORIGINS=http://localhost:3000
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,localhost:8000,127.0.0.1,127.0.0.1:3000,127.0.0.1:8000
SCRAMBLE_PUBLIC_DOCS=true

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

REVERB_APP_ID=replace-with-reverb-app-id
REVERB_APP_KEY=replace-with-reverb-app-key
REVERB_APP_SECRET=replace-with-reverb-app-secret
REVERB_HOST="reverb"
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=null
MAIL_LOGO_URL=
MAIL_FROM_ADDRESS="your-email@gmail.com"
MAIL_FROM_NAME="E-Tutoring"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

ANALYTICS_PROPERTY_ID=
# ANALYTICS_PROPERTY_ID=529372814

# Minutes to cache GA Data API responses (0 = no cache; recommended while testing Safari/new pages).
# New page views can still take hours to show in standard reports—confirm in GA4 Admin → DebugView (dev) or Reports.
ANALYTICS_CACHE_LIFETIME_MINUTES=5

# Standard report lookback (days). Wider window helps if GA4 is slow to process.
# ANALYTICS_REPORTING_DAYS=90
# Cache store for GA API only (default file). Use redis only if phpredis is installed.
# ANALYTICS_CACHE_STORE=file
