APP_NAME=E-Tutoring
APP_ENV=production
APP_KEY=base64:replace-with-generated-app-key
APP_DEBUG=false
APP_URL=http://your-production-host

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=daily
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=e_tutoring
DB_USERNAME=laravel
DB_PASSWORD=replace-with-strong-db-password
DB_ROOT_PASSWORD=replace-with-strong-root-password

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax
SANCTUM_EXPIRATION=43200

CORS_ALLOWED_ORIGINS=http://your-production-host
SANCTUM_STATEFUL_DOMAINS=your-production-host
SCRAMBLE_PUBLIC_DOCS=false

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

REVERB_APP_ID=replace-with-reverb-app-id
REVERB_APP_KEY=replace-with-reverb-app-key
REVERB_APP_SECRET=replace-with-reverb-app-secret
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

VITE_REVERB_APP_KEY=replace-with-reverb-app-key
VITE_REVERB_HOST=your-production-host
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME=http

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=null
MAIL_LOGO_URL=
MAIL_FROM_ADDRESS="your-email@gmail.com"
MAIL_FROM_NAME="E-Tutoring"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
