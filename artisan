#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "${ROOT_DIR}"

env_name="local"
if [[ "${1-}" == "--prod" ]]; then
  env_name="prod"
  shift
elif [[ "${1-}" == "--local" ]]; then
  env_name="local"
  shift
fi

if [[ "${env_name}" == "prod" ]]; then
  env_file="backend/.env"
  compose_file="docker-compose.prod.yml"
else
  env_file="backend/.env"
  compose_file="docker-compose.local.yml"
  if [[ ! -f "${env_file}" ]]; then
    if [[ -f "backend/.env.local.example" ]]; then
      cp "backend/.env.local.example" "${env_file}"
      echo "Created ${env_file} from backend/.env.local.example."
    else
      echo "Error: missing ${env_file} and backend/.env.local.example." >&2
      exit 1
    fi
  fi
fi

compose=(docker compose --env-file "${env_file}" -f "${compose_file}")

exec_tty_flag=""
if [[ -n "${CI-}" ]]; then
  exec_tty_flag="-T"
fi

php_container_id="$("${compose[@]}" ps -q php 2>/dev/null || true)"
if [[ -n "${php_container_id}" ]]; then
  if [[ -n "${exec_tty_flag}" ]]; then
    "${compose[@]}" exec "${exec_tty_flag}" php php artisan "$@"
  else
    "${compose[@]}" exec php php artisan "$@"
  fi
else
  "${compose[@]}" run --rm php php artisan "$@"
fi
