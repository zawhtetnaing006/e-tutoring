# Laravel API base URL
VITE_API_BASE_URL=http://localhost:8000/api

# Google Analytics 4 — must match GA4 → Admin → Data streams → Web → Measurement ID (G-…).
# Required for production `docker compose -f docker-compose.prod.yml build`: set the same name in
# repo root `.env` as VITE_GA_MEASUREMENT_ID (see docker-compose.prod.env.example).
VITE_GA_MEASUREMENT_ID=G-CKTMDBJZSE
