# Laravel API base URL
VITE_API_BASE_URL=http://localhost:8000/api

# Google Analytics 4 — must match GA4 → Admin → Data streams → Web → Measurement ID (G-…).
#
# SPA: disable GA4 Enhanced measurement → Page views for this web stream (or you get two page_view
# hits per route: history-based + this app’s tracker). GA4 Admin → Data streams → Web → Enhanced measurement.
VITE_GA_MEASUREMENT_ID=G-CKTMDBJZSE
